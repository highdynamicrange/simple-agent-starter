# LiteLLM model identifier: provider/model-name
LLM_MODEL=openai/gpt-4.1-mini

# Optional custom endpoint for OpenAI-compatible services.
LLM_API_BASE=

# Add only the key for the provider you use.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

AGENT_MAX_STEPS=5
AGENT_MAX_INPUT_CHARS=4000
AGENT_DEBUG=false
